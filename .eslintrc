            "prev": [
              "var",
              "let",
              "const",
              "try",
              "throw",
              "if",
              "for",
              "do",
              "while",
              "switch",
              "case",
              "default",
              "class",
              "function",
              "iife",
              "with",
              "return",
              "break",
              "continue",
              "debugger"
